{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "file://{env:HOME}/opencode-starter-kit/packages/plugins/jcodemunch-opencode-plugin/index.js"
  ],
  "mcp": {
    "jcodemunch": {
      "type": "local",
      "command": ["uvx", "jcodemunch-mcp"]
    }
  },
  "instructions": [
    "{env:HOME}/opencode-starter-kit/instructions/jcodemunch-opencode-policy.md"
  ],
  "lsp": {
    "ruff": {
      "command": ["uv", "run", "ruff-lsp"],
      "extensions": [".py", ".pyi"]
    }
  }
}
