{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@jcodemunch/opencode-plugin"],
  "mcp": {
    "jcodemunch": {
      "type": "local",
      "command": ["uvx", "jcodemunch-mcp"]
    }
  },
  "lsp": {
    "ruff": {
      "command": ["uv", "run", "ruff-lsp"],
      "extensions": [".py", ".pyi"]
    }
  }
}
